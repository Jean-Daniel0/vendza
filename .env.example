# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Supabase Database Variables
VITE_SUPABASE_URL=""
VITE_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""

# MonCash Payment Credentials
MONCASH_CLIENT_ID=""
MONCASH_CLIENT_SECRET=""
MONCASH_MODE="sandbox"
MONCASHCONNECT_KEY=""

# MonCashConnect SDK / Custom sandbox setup
MCC_SECRET=""
MCC_WEBHOOK_SECRET=""
MCC_DOMAIN=""

# Stripe Payment Credentials
STRIPE_PUBLISHABLE_KEY=""
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
BASE_URL=""

# Real-time exchange rate credentials
EXCHANGE_RATE_API_KEY=""

# Sightengine API Credentials for Image Quality & Type Filtering
SIGHTENGINE_API_USER=""
SIGHTENGINE_API_SECRET=""

# OneSignal Web SDK REST API Key
ONESIGNAL_REST_API_KEY=""



